#include <iostream>
#include<string>
#include<limits>
using namespace std;

struct Player {
    string name;
};

struct Teams {
    string name;
    string department;
    string id;
    int section;
    int year;
    bool topTeam = false;
    bool grouped = false;
    int win = 0;
    int loses = 0;
    int draw = 0;
    int played = 0;
    int points = 0;
    Player player[10];
    int numberOfPlayer = 0;
};

struct group {
    string name;
    Teams groupTeam[4];
};

const int NUM_GROUPS = 4;
const int MAX_TEAMS = 16;
group groups[NUM_GROUPS];
Teams team[MAX_TEAMS];
Teams topTeams[8];
int numberofTeam = 0;
int numberOfTeamToAdd = 0;

void Menu();

void AddTeams() {
    cout << "How many teams do you want to add (Max: " << MAX_TEAMS << ")" << endl;
    cin >> numberOfTeamToAdd;
    
    if(cin.fail() || numberofTeam+numberOfTeamToAdd>16 || numberofTeam+numberOfTeamToAdd<=0) {
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "You cannot register more than 16 teams or less than 1 team" << endl;
    }
    else if (numberofTeam + numberOfTeamToAdd <= MAX_TEAMS) {
        for (int i = numberofTeam; i < numberofTeam + numberOfTeamToAdd; i++) {
            cout << "Enter the name of team " << i + 1 << ": ";
            cin >> team[i].name;
            
            cout << "Enter the department of team " << i + 1 << ": ";
            cin >> team[i].department;
            
            cout << "Enter the year of team " << i + 1 << ": ";
            cin >> team[i].year;
            
            cout << "Enter the section of team " << i + 1 << ": ";
            cin >> team[i].section;
            
            team[i].numberOfPlayer = 0;
        }
        numberofTeam += numberOfTeamToAdd;
        system("cls");
        cout << "Team Has Been Registered Successfully" << endl;
    }
}

void DisplayEverything() {
    system("cls");
    if (numberofTeam == 0)
        cout << "There are no teams" << endl;
    else {
        for (int i = 0; i < numberofTeam; i++) {
            cout << team[i].name << endl;
            cout << "-------------" << endl;
            for (int j = 0; j < team[i].numberOfPlayer; j++) {
                cout << j+1 << ". " << team[i].player[j].name << endl;
            }
            cout << endl;
        }
    }
}

void AddPlayer() {
    system("cls");
    if (numberofTeam == 0) {
        cout << "There are no teams available \nAdd teams first" << endl;
        return;
    }
    
    cout << "List Of Available Teams" << endl;
    cout << "-----------------------" << endl;
    
    for (int i = 0; i < numberofTeam; i++) {
        cout << i << " " << team[i].name << endl;
    }
    
    cout << "-----------------------" << endl;
    cout << "Choose A Team To Add Players To..." << endl;
    
    int teamChoice;
    cin >> teamChoice;
    
    if(cin.fail() || teamChoice < 0 || teamChoice >= numberofTeam) {
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "Invalid team choice!" << endl;
        return;
    }
    
    system("cls");
    cout << team[teamChoice].name << endl;
    cout << "-----------------------" << endl;
    
    cout << "How many players do you want to add (max 10)? " << endl;
    int numberOfPlayersToADD;
    cin >> numberOfPlayersToADD;
    
    if(cin.fail() || numberOfPlayersToADD <= 0 || team[teamChoice].numberOfPlayer + numberOfPlayersToADD > 10) {
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "You cannot add more than 10 players to a team or less than 1 player" << endl;
        return;
    }
    
    for (int j = team[teamChoice].numberOfPlayer; j < team[teamChoice].numberOfPlayer + numberOfPlayersToADD; j++) {
        cout << "Enter the name of the player " << j + 1 << ": ";
        cin >> team[teamChoice].player[j].name;
    }
    team[teamChoice].numberOfPlayer += numberOfPlayersToADD;
    system("cls");
    cout << "Players Has Been Registered Successfully" << endl;
}

void AddGroup() {
    system("cls");
    
    if (numberofTeam < 4) {
        cout << "There Is Not Enough Team Available... (Add At least 4 Teams)\n" << endl;
        return;
    }
    
    cout << "Choose a group to add teams to" << endl;
    cout << "------------------------------" << endl;
    
    for (int k = 0; k < NUM_GROUPS; k++) {
        cout << k << " " << groups[k].name << endl;
    }
    cout << "------------------------------" << endl;
    
    int groupChoice;
    cin >> groupChoice;
    
    if(cin.fail() || groupChoice < 0 || groupChoice >= NUM_GROUPS) {
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "Invalid group choice!" << endl;
        return;
    }
    
    system("cls");
    
    cout << "Available Teams" << endl;
    cout << "---------------" << endl;
    
    for (int l = 0; l < numberofTeam; l++) {
        if (!team[l].grouped) {
            cout << l << " " << team[l].name << endl;
        }
    }
    cout << "---------------" << endl;
    
    int teamChoice;
    int teamsAdded = 0;
    
    for (int m = 0; m < 4; m++) {
        cout << "Choose A Team To Add (Team " << m+1 << " of 4)..." << endl;
        cin >> teamChoice;
        
        if(cin.fail() || teamChoice < 0 || teamChoice >= numberofTeam || team[teamChoice].grouped) {
            cin.clear();
            cin.ignore(numeric_limits<streamsize>::max(), '\n');
            cout << "Invalid or already grouped team! Try again." << endl;
            m--;
            continue;
        }
        
        groups[groupChoice].groupTeam[m] = team[teamChoice];
        team[teamChoice].grouped = true;
        teamsAdded++;
    }
    
    if(teamsAdded == 4) {
        system("cls");
        cout << "Teams added to group successfully!" << endl;
    }
}

void InitializeGroup() {
    string groupNames[NUM_GROUPS] = { "Group One", "Group Two", "Group Three", "Group Four" };
    for (int i = 0; i < NUM_GROUPS; ++i) {
        groups[i].name = groupNames[i];
    }
}

