void UpdateStanding() {
    system("cls");
    
    bool hasTeams = false;
    for(int i = 0; i < NUM_GROUPS; i++) {
        if(groups[i].groupTeam[0].name != "") {
            hasTeams = true;
            break;
        }
    }
    
    if(!hasTeams) {
        cout << "No teams have been assigned to groups yet!" << endl;
        return;
    }
    
    cout << "-------------------------------------" << endl;
    cout << "Group Standings to be Updated" << endl;
    cout << "-------------------------------------" << endl;
    
    for (int i = 0; i < NUM_GROUPS; i++) {
        if(groups[i].groupTeam[0].name == "") continue;
        
        cout << i << " Group " << groups[i].name << " Standings" << endl;
        cout << "-------------------------------------" << endl;
        
        for (int j = 0; j < 4; j++) {
            if(groups[i].groupTeam[j].name != "") {
                cout << j << " " << groups[i].groupTeam[j].name;
                cout << " | Played: " << groups[i].groupTeam[j].played;
                cout << " | Wins: " << groups[i].groupTeam[j].win;
                cout << " | Losses: " << groups[i].groupTeam[j].loses;
                cout << " | Draws: " << groups[i].groupTeam[j].draw;
                cout << " | Points: " << groups[i].groupTeam[j].points << endl;
            }
        }
        cout << "-------------------------------------" << endl;
    }
    
    cout << "Choose A Group...\n" << endl;
    
    int groupChoice;
    cin >> groupChoice;
    
    if(cin.fail() || groupChoice < 0 || groupChoice >= NUM_GROUPS || groups[groupChoice].groupTeam[0].name == "") {
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "Invalid group choice!" << endl;
        return;
    }
    
    for (int m = 0; m < 4; m++) {
        if(groups[groupChoice].groupTeam[m].name == "") continue;
        
        cout << "\n-------------------------------------" << endl;
        cout << groups[groupChoice].groupTeam[m].name << endl;
        cout << "-------------------------------------" << endl;
        
        cout << "Enter Played Value: ";
        cin >> groups[groupChoice].groupTeam[m].played;
        
        cout << "Enter Win Value: ";
        cin >> groups[groupChoice].groupTeam[m].win;
        
        cout << "Enter Lose Value: ";
        cin >> groups[groupChoice].groupTeam[m].loses;
        
        cout << "Enter Draw Value: ";
        cin >> groups[groupChoice].groupTeam[m].draw;
        
        cout << "Enter Point Value: ";
        cin >> groups[groupChoice].groupTeam[m].points;
        
        system("cls");
    }
    cout << "Standings updated successfully!" << endl;
}

void DisplayTopTeam() {
    system("cls");
    
    cout << "-------------------------------------" << endl;
    cout << "Top Teams" << endl;
    cout << "-------------------------------------" << endl;
    
    int topTeamIndex = 0;
    
    for (int o = 0; o < NUM_GROUPS; o++) {
        if(groups[o].groupTeam[0].name == "") continue;
        
        Teams sortedTeam[4];
        
        for (int j = 0; j < 4; ++j) {
            sortedTeam[j] = groups[o].groupTeam[j];
        }
        
        cout << "\nGroup " << groups[o].name << endl;
        cout << "-------------------------------------" << endl;
        
        for (int j = 0; j < 4; ++j) {
            for (int k = 0; k < 3 - j; ++k) {
                if (sortedTeam[k].points < sortedTeam[k + 1].points) {
                    Teams temp = sortedTeam[k];
                    sortedTeam[k] = sortedTeam[k + 1];
                    sortedTeam[k + 1] = temp;
                }
            }
        }
        
        cout << "1st: " << sortedTeam[0].name << " - Points: " << sortedTeam[0].points << endl;
        cout << "2nd: " << sortedTeam[1].name << " - Points: " << sortedTeam[1].points << endl;
        
        if(topTeamIndex < 8) {
            topTeams[topTeamIndex++] = sortedTeam[0];
            topTeams[topTeamIndex++] = sortedTeam[1];
        }
        
        cout << "----------------------------\n";
    }
}

void DisplayKnockoutStage() {
    system("cls");
    
    cout << "-------------------------------------" << endl;
    cout << "Quarter Final" << endl;
    cout << "-------------------------------------" << endl;
    cout << "Game One: " << topTeams[0].name << " Vs " << topTeams[2].name << endl;
    cout << "Game Two: " << topTeams[1].name << " Vs " << topTeams[3].name << endl;
    cout << "Game Three: " << topTeams[4].name << " Vs " << topTeams[6].name << endl;
