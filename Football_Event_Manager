    cout << "\n-------------------------------------\n" << endl;
    cout << "Semi Final" << endl;
    cout << "-------------------------------------" << endl;
    cout << "Winner of Game One vs Winner of Game Two" << endl;
    cout << "Winner of Game Three vs Winner of Game Four" << endl;
    
    cout << "\n-------------------------------------\n" << endl;
    cout << "Final" << endl;
    cout << "-------------------------------------" << endl;
    cout << "Winner of Semi Final 1 vs Winner of Semi Final 2" << endl;
}

void userchoice(int input) {
    switch (input) {
    case 1:
        AddTeams();
        break;
    case 2:
        AddPlayer();
        break;
    case 3:
        AddGroup();
        break;
    case 4:
        DisplayGroupMatch();
        break;
    case 5:
        UpdateStanding();
        break;
    case 6:
        DisplayTopTeam();
        break;
    case 7:
        DisplayKnockoutStage();
        break;
    case 8:
        DisplayEverything();
        break;
    default:
        cout << "Your input must be between 0 and 8" << endl;
        break;
    }
}

void Menu() {
    int userInput = -1;
    
    while (userInput != 0) {
        cout << "\n***************************\n";
        cout << "******** Main Menu ********\n";
        cout << "1. Add Team\n";
        cout << "2. Add Player\n";
        cout << "3. Add team to group\n";
        cout << "4. Display Group Matches\n";
        cout << "5. Update Standings\n";
        cout << "6. Display Top Teams\n";
        cout << "7. Display knockout stage\n";
        cout << "8. Display Teams and their players\n";
        cout << "0. Exit\n";
        cout << "Enter Your Choice: ";
        
        cin >> userInput;
        
        if (cin.fail()) {
            cout << "Invalid input. Please enter a number.\n";
            cin.clear();
            cin.ignore(numeric_limits<streamsize>::max(), '\n');
        }
        else if (userInput == 0) {
            cout << "Exiting.....";
            break;
        }
        else if (userInput >= 1 && userInput <= 8) {
            userchoice(userInput);
        }
        else {
            cout << "Your input must be between 0 and 8" << endl;
        }
    }
}

int main() {
    InitializeGroup();
    Menu();
    return 0;
}
